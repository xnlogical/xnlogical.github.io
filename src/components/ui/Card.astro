---
interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;

const mediaContent = await Astro.slots.render("media");
const isContainer = className.split(" ").includes("container");
---

<div
    class={`
        group block rounded-2xl overflow-hidden text-sm font-mono relative

        border border-white/40 dark:border-white/[0.12]

        shadow-[inset_0_2px_4px_rgba(255,255,255,0.2),0_10px_25px_-5px_rgba(0,0,0,0.08),0_1px_1px_rgba(0,0,0,0.05)]
        dark:shadow-[inset_0_1.5px_3px_rgba(255,255,255,0.1),0_15px_30px_-10px_rgba(0,0,0,0.5),inset_0_-1px_2px_rgba(0,0,0,0.4)]

        transition-all duration-300 cubic-bezier(0.25, 0.8, 0.25, 1)
        transform-gpu origin-center

        hover:[transform:rotateX(2deg)_translateY(-1px)]

        hover:shadow-[inset_0_3px_6px_rgba(255,255,255,0.3),0_16px_32px_-4px_rgba(0,0,0,0.12)]
        dark:hover:shadow-[inset_0_2.5px_5px_rgba(255,255,255,0.15),0_20px_40px_-8px_rgba(0,0,0,0.6)]

        ${
            isContainer
                ? `
            backdrop-blur-md
            bg-gradient-to-b from-white/40 to-white/10
            dark:from-white/[0.07] dark:to-transparent

            hover:bg-gradient-to-b hover:from-white/50 hover:to-white/15
            dark:hover:from-white/[0.12] dark:hover:to-white/[0.02]
        `
                : `
            bg-gradient-to-b from-white/95 to-white/90
            dark:from-[#0b0b0c]/90 dark:to-[#0b0b0c]/85

            hover:from-white/100 hover:to-white/95
            dark:hover:from-[#0b0b0c]/95 dark:hover:to-[#0b0b0c]/90
        `
        }

        ${className}
    `
        .replace(/\s+/g, " ")
        .trim()}
>
    {
        mediaContent && (
            <div class="w-full aspect-video overflow-hidden bg-black/20 relative border-b border-white/20 dark:border-white/[0.08]">
                <div class="w-full h-full [&>*]:w-full [&>*]:h-full [&>*]:object-cover group-hover:scale-[1.01] transition-transform duration-700 ease-out">
                    <Fragment set:html={mediaContent} />
                </div>
            </div>
        )
    }

    <div class="p-4 flex flex-col gap-1.5 relative z-10">
        <slot />
        {
            Astro.slots.has("footer") && (
                <div class="pt-2 flex flex-wrap gap-2 mt-auto">
                    <slot name="footer" />
                </div>
            )
        }
    </div>
</div>
