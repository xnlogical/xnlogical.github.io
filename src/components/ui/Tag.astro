---
interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;
---

<span
    class={`
        inline-flex items-center text-[10px] font-bold px-2.5 py-0.5 rounded-full select-none font-sans uppercase tracking-wider

        /* Smooth Plastic Gradient Face */
        bg-gradient-to-b from-[var(--color-tag-bg)] to-[rgba(213,96,29,0.03)]
        dark:to-[rgba(238,123,67,0.01)]

        /* Bound System Tokens */
        border border-[var(--color-tag-border)]

        /* 3D Cushion Highlights */
        shadow-[inset_0_1.5px_2px_rgba(255,255,255,0.3),0_2px_4px_rgba(0,0,0,0.1)]
        dark:shadow-[inset_0_1px_1.5px_rgba(255,255,255,0.08),0_3px_6px_rgba(0,0,0,0.4)]

        /* Animation Engine */
        transition-all duration-300 cubic-bezier(0.34, 1.56, 0.64, 1) transform-gpu

        /* Dynamic Hover Using Theme Tokens */
        hover:scale-105 hover:-translate-y-[0.5px]
        hover:border-[var(--color-tag-border-hover)]
        hover:shadow-[inset_0_2px_3px_rgba(255,255,255,0.5),0_4px_8px_rgba(0,0,0,0.15)]
        dark:hover:shadow-[inset_0_1.5px_2px_rgba(255,255,255,0.15),0_6px_10px_rgba(0,0,0,0.5)]

        active:scale-95 active:translate-y-0
        ${className}
    `
        .replace(/\s+/g, " ")
        .trim()}
    style="color: var(--color-tag-text);"
>
    <slot />
</span>
