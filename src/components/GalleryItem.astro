---
import Tag from "./ui/Tag.astro";
import BaseCard from "./ui/Card.astro";

interface Props {
    title: string;
    caption: string;
    location?: string;
    tags?: string[];
    class?: string;
}

const {
    title,
    caption,
    location,
    tags = [],
    class: className = "",
} = Astro.props;
---

<BaseCard class={className}>
    <Fragment slot="media">
        <div class="video-safe-wrapper w-full h-full relative group/video">
            <slot name="media" />
        </div>
    </Fragment>

    <div class="flex justify-between items-baseline gap-4 mt-1">
        <h3
            class="font-bold text-xl tracking-tight truncate"
            style="color: var(--color-card-text);"
        >
            {title}
        </h3>
        {
            location && (
                <span
                    class="text-xs font-mono font-bold uppercase tracking-wider shrink-0 select-none opacity-80"
                    style="color: var(--color-tag-text);"
                >
                    @{location}
                </span>
            )
        }
    </div>

    <p
        class="text-sm leading-relaxed max-w-prose"
        style="color: var(--color-card-text-muted);"
    >
        {caption}
    </p>

    {
        tags.length > 0 && (
            <Fragment slot="footer">
                {tags.map((tag) => (
                    <Tag>{tag}</Tag>
                ))}
            </Fragment>
        )
    }
</BaseCard>

<script>
    function secureVideoPlaybacks() {
        const videos = document.querySelectorAll(
            ".video-safe-wrapper video",
        ) as NodeListOf<HTMLVideoElement>;

        videos.forEach((video) => {
            video.setAttribute("playsinline", "");
            video.setAttribute("webkit-playsinline", "");

            if (!video.hasAttribute("preload")) {
                video.setAttribute("preload", "metadata");
            }

            if (video.hasAttribute("autoplay")) {
                video.muted = true;
                video.setAttribute("muted", "");

                video.play().catch(() => {
                    video.addEventListener("click", () => video.play(), {
                        once: true,
                    });
                });
            }
        });
    }

    document.addEventListener("astro:page-load", secureVideoPlaybacks);
</script>
