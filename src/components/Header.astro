---
import "../styles/tooltip.css";
import { NAV_LINKS } from "../config";

const { navbarActiveItemID } = Astro.props;
const activeClasses = [
    "text-[var(--color-accent)]",
    "font-bold",
    "bg-[var(--color-accent)]/[0.08]",
    "border-[var(--color-accent)]/30",
    "dark:border-[var(--color-accent)]/20",
];
---

<header id="main-header" class="py-5 relative z-50 perspective-[1000px]">
    {
        /* Increased tracking envelope from max-w-7xl to max-w-none / w-full bounds */
    }
    <div class="mx-auto w-full max-w-none">
        <div
            class="/* ── GLASSMORPHIC CORE ── */
                bg-gradient-to-b from-white/40 to-white/10
                dark:from-white/[0.07] dark:to-transparent
                backdrop-blur-md
                /* Structural Specular Rims */
                border border-white/40 dark:border-white/[0.12]
                text-sm rounded-full font-mono
                /* Base 3D Glass Cushion Shadows */
                shadow-[inset_0_2px_4px_rgba(255,255,255,0.7),0_10px_25px_-5px_rgba(0,0,0,0.08),0_1px_1px_rgba(0,0,0,0.05)]
                dark:shadow-[inset_0_1.5px_3px_rgba(255,255,255,0.2),0_15px_30px_-10px_rgba(0,0,0,0.5),inset_0_-1px_2px_rgba(0,0,0,0.4)]
                /* ── KINETIC ROLLING ENGINE ── */
                transition-all duration-300 cubic-bezier(0.25, 0.8, 0.25, 1)
                transform-gpu origin-center
                /* The Hover Roll: Tilt forward, compressing the glass highlight */
                hover:[transform:rotateX(5deg)_translateY(-1px)]
                /* Dynamic Glass Refraction Shift on Hover */
                hover:bg-gradient-to-b hover:from-white/50 hover:to-white/15
                dark:hover:from-white/[0.12] dark:hover:to-white/[0.02]
                hover:shadow-[inset_0_3px_6px_rgba(255,255,255,0.9),0_16px_32px_-4px_rgba(0,0,0,0.12)]
                dark:hover:shadow-[inset_0_2.5px_5px_rgba(255,255,255,0.35),0_20px_40px_-8px_rgba(0,0,0,0.6)]"
        >
            <nav
                id="navigation-menu"
                aria-label="Main menu"
                class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 px-6 py-2"
            >
                <div
                    class="flex items-center justify-between sm:justify-start gap-4"
                >
                    <div class="flex items-center gap-2 group/logo py-1">
                        <span
                            class="text-[var(--color-secondary)] text-base transition-transform duration-300 group-hover/logo:-rotate-12"
                            >$</span
                        >
                        <span class="text-[var(--color-muted)] text-base"
                            >./</span
                        >
                        <a
                            href="/"
                            target="_self"
                            class="text-[var(--color-primary)] font-bold text-base tracking-tight hover:text-[var(--color-accent)] transition-colors duration-200"
                        >
                            xnlogical
                        </a>
                    </div>
                </div>
                <div
                    class="flex flex-wrap items-center gap-2 sm:gap-1 text-xs overflow-visible"
                >
                    {
                        NAV_LINKS.map((link) => {
                            return (
                                <a
                                    href={link.redirect ?? link.url}
                                    target={link.redirect ? "_blank" : "_self"}
                                    id={link.id}
                                    class:list={[
                                        /* ── HIGH-FI TACTILE LINKS ── */
                                        "text-[var(--color-secondary)] hover:text-[var(--color-primary)]",
                                        "font-medium tracking-tight px-3.5 py-1.5 rounded-full border border-transparent",
                                        "transition-all duration-300 transform-gpu",

                                        /* Subtle Hover Micro-Glow and Glass Tint Backdrops */
                                        "hover:bg-white/20 dark:hover:bg-white/[0.04]",
                                        "hover:border-white/30 dark:hover:border-white/[0.06]",
                                        "hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)] dark:hover:shadow-none",
                                        "hover:-translate-y-[1px] active:translate-y-[0.5px]",

                                        link.tooltip && "tooltip",
                                    ]}
                                    data-tooltip={link.tooltip}
                                >
                                    {link.title}
                                </a>
                            );
                        })
                    }
                </div>
            </nav>
        </div>
    </div>
</header>

<script
    define:vars={{
        navbarActiveItemID,
        activeClasses,
    }}
>
    const activeItemElement = document.getElementById(navbarActiveItemID);

    if (activeItemElement) {
        activeClasses.forEach((activeClass) => {
            activeItemElement.classList.add(activeClass);
        });
    }
</script>
