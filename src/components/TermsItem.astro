---
import BaseCard from "./ui/Card.astro";

interface Props {
    term: string;
    sections: string[];
    index: number;
    category?: string;
    class?: string;
    open?: boolean;
}

const {
    term,
    sections = [],
    index,
    category,
    class: className = "",
    open = false,
} = Astro.props;
const displayNum = String(index + 1).padStart(2, "0");
---

<BaseCard class={`!p-0 ${className}`}>
    <details class="group w-full block" {...open ? { open: true } : {}}>
        {/* Compact Summary Header with Active State Tints */}
        <summary
            class="cursor-pointer select-none py-1.5 px-3 flex items-center justify-between gap-2.5 hover:bg-[var(--color-tag-bg)]/30 group-open:bg-[var(--color-tag-bg)]/15 transition-colors outline-none border-b border-transparent group-open:border-[var(--color-card-border)]"
        >
            <div class="flex items-center gap-2 min-w-0 h-full">
                {/* Clean Index Indicator */}
                <span
                    class="font-mono text-xs font-bold opacity-50 shrink-0 tabular-nums"
                    style="color: var(--color-tag-text);"
                >
                    {displayNum}
                </span>

                {/* Technical Structural Separator */}
                <span
                    class="w-[1px] h-3 bg.5 bg-[var(--color-card-border)] opacity-60 shrink-0"
                ></span>

                {/* High-Readability Term */}
                <h3
                    class="font-bold text-sm tracking-tight truncate group-open:text-[var(--color-accent)] transition-colors"
                    style="color: var(--color-card-text);"
                >
                    {term}
                </h3>
            </div>

            <div class="flex items-center gap-2.5 shrink-0 h-full">
                {/* Pill Category Tag */}
                {
                    category && (
                        <span
                            class="text-[9px] font-mono tracking-wider px-1.5 py-0.5 rounded border border-[var(--color-tag-border)] opacity-80"
                            style="background: var(--color-tag-bg); color: var(--color-tag-text);"
                        >
                            {category}
                        </span>
                    )
                }

                {/* Heavy UTF-8 Geometric Toggle Blocks */}
                <div
                    class="w-3.5 h-3.5 flex items-center justify-center font-sans text-[10px] opacity-40 group-open:opacity-100 group-open:text-[var(--color-accent)] transition-all"
                >
                    <span class="group-open:hidden">▼</span>
                    <span class="hidden group-open:inline">▲</span>
                </div>
            </div>
        </summary>

        {/* Dense Text Block Layer */}
        <article
            class="px-3 py-2 text-xs leading-relaxed space-y-1.5 bg-black/[0.02] dark:bg-black/10"
            style="color: var(--color-card-text-muted);"
        >
            {sections.map((paragraph) => <p class="max-w-none">{paragraph}</p>)}
        </article>
    </details>
</BaseCard>

<style>
    summary::-webkit-details-marker,
    summary::marker {
        display: none;
    }
</style>
