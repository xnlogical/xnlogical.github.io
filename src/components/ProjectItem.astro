---
import BaseCard from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import Tag from "./ui/Tag.astro";

interface Props {
    title: string;
    description: string;
    link?: string;
    media?: string;
    tags?: string[];
}

const { title, description, link, media, tags = [] } = Astro.props;
---

<BaseCard>
    {
        media !== undefined && media !== "" ? (
            <Fragment slot="media">
                <img
                    src={media}
                    alt={title}
                    class="w-full h-full object-cover block"
                    loading="lazy"
                />
            </Fragment>
        ) : null
    }

    <div class="flex justify-between items-start gap-4">
        <h3 class="font-bold text-xl" style="color: var(--color-card-text);">
            {title}
        </h3>
        {link !== undefined ? <Button href={link}> Visit ↗ </Button> : null}
    </div>

    <p
        class="text-sm leading-relaxed"
        style="color: var(--color-card-text-muted);"
    >
        {description}
    </p>

    {
        tags.length > 0 && (
            <Fragment slot="footer">
                {tags.map((tag) => (
                    <Tag>{tag}</Tag>
                ))}
            </Fragment>
        )
    }
</BaseCard>
