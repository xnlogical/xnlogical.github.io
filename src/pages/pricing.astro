---
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

interface WizardOption {
    id: string;
    label: string;
    min: number;
    max: number;
    days: number;
    multiplier?: number;
}

interface WizardStep {
    id: string;
    title: string;
    question: string;
    type: "single" | "multi";
    options: WizardOption[];
}

const wizardSteps: WizardStep[] = [
    {
        id: "type",
        title: "Type",
        question: "Select the type of work needed:",
        type: "single",
        options: [
            {
                id: "patch",
                label: "Patch/bugfix",
                min: 50,
                max: 75,
                days: 3,
            },
            {
                id: "system",
                label: "Game system",
                min: 120,
                max: 250,
                days: 7,
            },
            {
                id: "game",
                label: "Full game",
                min: 400,
                max: 550,
                days: 21,
            },
        ],
    },
    {
        id: "complexity",
        title: "Complexity",
        question: "Select the complexity of the work needed:",
        type: "single",
        options: [
            {
                id: "basic",
                label: "Low complexity (trivially complex mechanics, e.g. word guessers)",
                min: 0,
                max: 0,
                days: 0,
                multiplier: 0.8,
            },
            {
                id: "standard",
                label: "Standard complexity (standard mechanics, e.g. brainrot)",
                min: 100,
                max: 150,
                days: 3,
                multiplier: 1,
            },
            {
                id: "high",
                label: "High complexity (complex mechanics, e.g. FPS)",
                min: 300,
                max: 450,
                days: 7,
                multiplier: 1.2,
            },
        ],
    },
    {
        id: "extra",
        title: "Extra features",
        question: "Select any extra feature(s):",
        type: "multi",
        options: [
            {
                id: "data",
                label: "Data Storage",
                min: 50,
                max: 75,
                days: 1,
            },
        ],
    },
    {
        id: "timeline",
        title: "Delivery Urgency",
        question: "Please select the desired urgency package:",
        type: "single",
        options: [
            {
                id: "standard",
                label: "Standard Delivery",
                min: 0,
                max: 0,
                days: 0,
                multiplier: 1.0,
            },
            {
                id: "expedited",
                label: "Expedited Delivery",
                min: 150,
                max: 200,
                days: -5,
                multiplier: 1.1,
            },
            {
                id: "rush",
                label: "Critical Rush",
                min: 250,
                max: 400,
                days: -12,
                multiplier: 1.25,
            },
        ],
    },
];
---

<BaseLayout activeNavbarItemID="pricing">
    <main class="flex justify-center p-4">
        <Card class="container w-full max-w-2xl px-4 py-2">
            <div id="wizard-container">
                <div
                    class="flex items-center gap-1 mb-6 border-b pb-3"
                    style="border-color: var(--color-card-border);"
                >
                    <span
                        id="step-badge"
                        class="text-[10px] font-mono font-bold uppercase px-2 py-0.5 rounded bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] border border-[var(--color-tag-border)]"
                    >
                        Initialization
                    </span>
                    <h3
                        id="step-title"
                        class="text-sm font-bold tracking-tight text-[var(--color-primary)] ml-2"
                    >
                        ---
                    </h3>
                </div>

                <form
                    id="wizard-form"
                    autocomplete="off"
                    onsubmit="return false;"
                >
                    {
                        wizardSteps.map((step, idx) => (
                            <div
                                class="wizard-step-panel hidden space-y-4"
                                data-step-index={idx}
                            >
                                <p
                                    class="text-sm font-medium"
                                    style="color: var(--color-card-text);"
                                >
                                    {step.question}
                                </p>

                                <div class="grid grid-cols-1 gap-2">
                                    {step.options.map((opt) => (
                                        <label
                                            class="flex items-center justify-between p-3 rounded-xl border cursor-pointer select-none transition-all duration-200 bg-[var(--color-surface)] hover:bg-[var(--color-tag-bg)]/20"
                                            style="border-color: var(--color-card-border);"
                                        >
                                            <div class="flex items-center gap-3">
                                                <input
                                                    type={
                                                        step.type === "multi"
                                                            ? "checkbox"
                                                            : "radio"
                                                    }
                                                    name={step.id}
                                                    value={opt.id}
                                                    data-label={opt.label}
                                                    data-min={opt.min}
                                                    data-max={opt.max}
                                                    data-days={opt.days}
                                                    data-multiplier={
                                                        opt.multiplier || 1.0
                                                    }
                                                    class="wizard-input w-4 h-4 accent-[var(--color-accent)] bg-black/40 border-[var(--color-card-border)] focus:ring-0"
                                                />
                                                <div class="flex flex-col">
                                                    <span class="text-xs font-mono text-[var(--color-card-text)]">
                                                        {opt.label}
                                                    </span>
                                                    <span class="text-[10px] text-[var(--color-muted)] font-mono mt-0.5">
                                                        {opt.days !== 0
                                                            ? `${opt.days > 0 ? "+" : ""}${opt.days} Days`
                                                            : "No timeline delta"}
                                                        {opt.multiplier &&
                                                        opt.multiplier > 1
                                                            ? ` • ${opt.multiplier}x Global Fee`
                                                            : ""}
                                                    </span>
                                                </div>
                                            </div>
                                            <span class="font-mono text-xs font-bold text-[var(--color-accent)]">
                                                {opt.min === 0 && opt.max === 0
                                                    ? "Included"
                                                    : `$${opt.min}-$${opt.max}`}
                                            </span>
                                        </label>
                                    ))}
                                </div>
                            </div>
                        ))
                    }

                    {/* ── SUMMARY MANIFEST PANEL ── */}
                    <div
                        id="wizard-summary-panel"
                        class="wizard-step-panel hidden space-y-4"
                        data-step-index={wizardSteps.length}
                    >
                        <p
                            class="text-sm font-medium text-[var(--color-card-text)]"
                        >
                            Review your custom deployment blueprint stack
                            details below before initialization:
                        </p>
                        <div
                            class="p-4 rounded-xl border space-y-3 bg-[var(--color-surface)]/50 text-xs font-mono"
                            style="border-color: var(--color-card-border);"
                        >
                            <div
                                class="flex justify-between border-b pb-2"
                                style="border-color: var(--color-card-border);"
                            >
                                <span class="text-[var(--color-muted)]"
                                    >Configuration Item</span
                                >
                                <span class="text-[var(--color-muted)]"
                                    >Delta Impact</span
                                >
                            </div>
                            <div id="summary-items-container" class="space-y-2">
                            </div>
                        </div>
                    </div>
                </form>

                {/* ── METRICS DISPLAY ── */}
                <div
                    class="grid grid-cols-2 gap-3 p-4 rounded-xl border mt-8"
                    style="border-color: var(--color-card-border); background-color: var(--color-surface);"
                >
                    <div>
                        <span
                            class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-muted)] block"
                            >Valuation Range</span
                        >
                        <span
                            id="wizard-total-range"
                            class="text-lg font-black text-[var(--color-accent)]"
                            >$0 - $0</span
                        >
                    </div>
                    <div
                        class="border-l pl-4"
                        style="border-color: var(--color-card-border);"
                    >
                        <span
                            class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-muted)] block"
                            >Estimated Delivery</span
                        >
                        <span
                            id="wizard-timeline"
                            class="text-lg font-black text-[var(--color-primary)] font-mono"
                            >0 Days</span
                        >
                    </div>
                </div>

                <div class="flex items-center justify-between pt-4 mt-4">
                    <Button id="wizard-prev-btn"> ← Previous </Button>
                    <Button id="wizard-next-btn"> Next → </Button>
                </div>
            </div>
        </Card>

        <script
            define:vars={{
                totalStepsCount: wizardSteps.length,
                stepTitles: wizardSteps.map((s) => s.title),
            }}
        >
            function initAdvancedWizard() {
                const form = document.getElementById("wizard-form");
                const rangeDisplay =
                    document.getElementById("wizard-total-range");
                const timelineDisplay =
                    document.getElementById("wizard-timeline");
                const prevBtn = document.getElementById("wizard-prev-btn");
                const nextBtn = document.getElementById("wizard-next-btn");
                const stepBadge = document.getElementById("step-badge");
                const stepTitle = document.getElementById("step-title");
                const summaryItemsContainer = document.getElementById(
                    "summary-items-container",
                );

                if (
                    !form ||
                    !rangeDisplay ||
                    !timelineDisplay ||
                    !prevBtn ||
                    !nextBtn ||
                    !stepBadge ||
                    !stepTitle ||
                    !summaryItemsContainer
                )
                    return;

                let currentIdx = 0;
                const panels = Array.from(
                    document.querySelectorAll(".wizard-step-panel"),
                );

                function updateUI() {
                    // Hide all views completely
                    panels.forEach((p) => p.classList.add("hidden"));

                    // Highlight target active view
                    const activePanel = panels.find(
                        (p) => parseInt(p.dataset.stepIndex) === currentIdx,
                    );
                    if (activePanel) activePanel.classList.remove("hidden");

                    if (currentIdx === totalStepsCount) {
                        // Summary View State Configuration
                        stepBadge.textContent = "Complete";
                        stepTitle.textContent =
                            "Final Scope Manifest Calculation";
                        nextBtn.textContent = "Deploy Configuration 🚀";
                        prevBtn.disabled = false;
                        buildSummaryManifest();
                    } else {
                        // Standard Input Step State Configuration
                        stepBadge.textContent = `Step ${(currentIdx + 1).toString().padStart(2, "0")}`;
                        stepTitle.textContent = stepTitles[currentIdx] || "";
                        nextBtn.textContent = "Next →";
                        prevBtn.disabled = currentIdx === 0;
                    }

                    tallyCalculations();
                }

                function buildSummaryManifest() {
                    summaryItemsContainer.innerHTML = "";
                    const checkedElements = form.querySelectorAll(
                        ".wizard-input:checked",
                    );

                    checkedElements.forEach((input) => {
                        const label = input.getAttribute("data-label");
                        const min = parseFloat(
                            input.getAttribute("data-min") || "0",
                        );
                        const max = parseFloat(
                            input.getAttribute("data-max") || "0",
                        );
                        const days = parseInt(
                            input.getAttribute("data-days") || "0",
                        );
                        const multiplier = parseFloat(
                            input.getAttribute("data-multiplier") || "1.0",
                        );

                        let costString =
                            min === 0 && max === 0
                                ? "Included"
                                : `$${min}-$${max}`;
                        if (multiplier !== 1.0)
                            costString = `${multiplier}x Fee Modifier`;

                        const row = document.createElement("div");
                        row.className =
                            "flex justify-between items-start gap-4 text-[var(--color-card-text)]";
                        row.innerHTML = `
                            <span class="text-left max-w-[70%] text-[var(--color-primary)]">↳ ${label}</span>
                            <div class="text-right flex flex-col items-end">
                                <span class="text-[var(--color-accent)] font-bold">${costString}</span>
                                <span class="text-[10px] text-[var(--color-muted)]">${days !== 0 ? (days > 0 ? "+" : "") + days + " Days" : "Standard Speed"}</span>
                            </div>
                        `;
                        summaryItemsContainer.appendChild(row);
                    });
                }

                function tallyCalculations() {
                    let baseMin = 0;
                    let baseMax = 0;
                    let totalDays = 0;
                    let absoluteMultiplier = 1.0;

                    const checkedElements = form.querySelectorAll(
                        ".wizard-input:checked",
                    );

                    form.querySelectorAll("label").forEach((l) => {
                        l.style.borderColor = "var(--color-card-border)";
                        l.style.background = "var(--color-surface)";
                    });

                    checkedElements.forEach((input) => {
                        baseMin += parseFloat(
                            input.getAttribute("data-min") || "0",
                        );
                        baseMax += parseFloat(
                            input.getAttribute("data-max") || "0",
                        );
                        totalDays += parseInt(
                            input.getAttribute("data-days") || "0",
                        );

                        const choiceMultiplier = parseFloat(
                            input.getAttribute("data-multiplier") || "1.0",
                        );
                        if (choiceMultiplier !== 1.0)
                            absoluteMultiplier = choiceMultiplier;

                        const label = input.closest("label");
                        if (label) {
                            label.style.borderColor = "var(--color-accent)";
                            label.style.background = "var(--color-tag-bg)";
                        }
                    });

                    const finalMin = Math.round(baseMin * absoluteMultiplier);
                    const finalMax = Math.round(baseMax * absoluteMultiplier);
                    const safeDays = Math.max(3, totalDays);

                    rangeDisplay.textContent = `$${finalMin.toLocaleString()} - $${finalMax.toLocaleString()}`;
                    timelineDisplay.textContent = `${safeDays} Days`;
                }

                nextBtn.addEventListener("click", (e) => {
                    e.preventDefault();

                    // If we are currently staring at the summary page, trigger confirmation workflow
                    if (currentIdx === totalStepsCount) {
                        alert(
                            "Configuration deployment initialized successfully!",
                        );
                        return;
                    }

                    const activePanel = panels.find(
                        (p) => parseInt(p.dataset.stepIndex) === currentIdx,
                    );
                    // Explicit fallback fallback check using standard form query selection matching name parameters
                    const currentInputs = activePanel
                        ? Array.from(
                              activePanel.querySelectorAll(".wizard-input"),
                          )
                        : [];
                    const hasSelection = currentInputs.some((i) => i.checked);

                    if (!hasSelection) {
                        if (activePanel) {
                            activePanel.style.animation =
                                "shake 0.3s ease-in-out";
                            setTimeout(
                                () => (activePanel.style.animation = ""),
                                300,
                            );
                        }
                        return;
                    }

                    // Advance purely on numerical sequence indexing rules
                    if (currentIdx < totalStepsCount) {
                        currentIdx++;
                        updateUI();
                    }
                });

                prevBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    if (currentIdx > 0) {
                        currentIdx--;
                        updateUI();
                    }
                });

                form.addEventListener("change", tallyCalculations);
                updateUI();
            }

            // Bind explicitly into Astro lifecycle processing systems
            document.addEventListener("astro:page-load", initAdvancedWizard);
        </script>

        <style>
            @keyframes shake {
                0%,
                100% {
                    transform: translateX(0);
                }
                25% {
                    transform: translateX(-4px);
                }
                75% {
                    transform: translateX(4px);
                }
            }
        </style>
    </main>
</BaseLayout>
